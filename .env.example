# ============================================================
# Pamaptor — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Database (required)
# Local: postgresql://postgres:yourpassword@localhost:5432/pamaptor
# Cloud Run: uses Cloud SQL Unix socket — see DEPLOY.md
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/pamaptor"

# ------------------------------------------------------------
# NextAuth (required)
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: base URL of the app (no trailing slash)
# ------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ------------------------------------------------------------
# GCP Cloud Storage (required in production)
# GCP_CREDENTIALS_PATH: local only — path to service account
# JSON key file. Leave empty in Cloud Run (uses ADC).
# ------------------------------------------------------------
GCP_PROJECT_ID="your-gcp-project-id"
GCS_BUCKET_NAME="pamaptor-media"
GCP_CREDENTIALS_PATH=""

# ------------------------------------------------------------
# Email — SMTP via Nodemailer (optional in development)
# Leave empty in dev to print emails to the console instead.
# For Gmail: enable 2FA, create App Password.
# See DEPLOY.md Step 4 for details.
# ------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Pamaptor <noreply@pamaptor.com>"

# ------------------------------------------------------------
# Admin Registration (required)
# This secret code must be entered when registering as admin.
# Generate: openssl rand -hex 24
# ------------------------------------------------------------
ADMIN_REGISTER_SECRET=""

# ------------------------------------------------------------
# App URL (required)
# Used for building absolute URLs in emails etc.
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# CDN URL (production only)
# Base URL for serving uploaded media through Cloudflare CDN.
# Leave empty in development — files will use storage.googleapis.com directly.
# Production value: https://cdn.pamaptor.com
# ------------------------------------------------------------
CDN_URL=""
