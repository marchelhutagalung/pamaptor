# ============================================================
# Pamaptor — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Database (required)
# Local: postgresql://postgres:yourpassword@localhost:5432/pamaptor
# Cloud Run: uses Cloud SQL Unix socket — see deployment docs
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/pamaptor"

# ------------------------------------------------------------
# NextAuth (required)
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: base URL of the app (no trailing slash)
# ------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ------------------------------------------------------------
# GCP Cloud Storage (required in production)
# GCP_CREDENTIALS_PATH: local only — path to service account
# JSON key file. Remove / leave empty in Cloud Run (uses
# Application Default Credentials instead).
# ------------------------------------------------------------
GCP_PROJECT_ID="your-gcp-project-id"
GCS_BUCKET_NAME="pamaptor-media"
GCP_CREDENTIALS_PATH=""

# ------------------------------------------------------------
# Email — Resend (optional in development)
# Leave empty in dev to print emails to the console instead.
# Get your API key at https://resend.com
# ------------------------------------------------------------
RESEND_API_KEY=""

# ------------------------------------------------------------
# Admin / Petugas Registration (required)
# This secret code must be entered when registering as Petugas.
# Change this to a strong random value before deploying.
# Generate: openssl rand -hex 24
# ------------------------------------------------------------
ADMIN_REGISTER_SECRET=""

# ------------------------------------------------------------
# App (required)
# Used for building absolute URLs in emails etc.
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
